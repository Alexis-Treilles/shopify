p":0,"margin_bottom":0,"additional_class":""},"blocks":{}}},"block_order":["text_VLtRib","text_FyFaMj","button_Q3UxFk","button_qUpbgY"]},"group_ampbiX":{"type":"group","name":"t:group","settings":{"show_on_display":"desktop_and_mobile","wrap_in_card":false,"color_scheme":"","show_card_border":false,"layout_type":"flex","width_desktop":100,"layout_direction_desktop":"column","layout_grid_columns_desktop":3,"layout_gap_desktop":10,"layout_wrap_desktop":"nowrap","layout_justify_desktop":"flex-start","layout_align_items_desktop":"flex-start","same_as_desktop":true,"width_mobile":100,"layout_direction_mobile":"column","layout_grid_columns_mobile":1,"layout_gap_mobile":10,"layout_wrap_mobile":"nowrap","layout_justify_mobile":"flex-start","layout_align_items_mobile":"flex-start","use_global_container_padding":true,"padding_horizontal":30,"padding_vertical":30,"margin_top":0,"margin_bottom":0,"additional_class":""},"blocks":{"text_XR3Gyx":{"type":"text","name":"t:title","settings":{"show_on_display":"desktop_and_mobile","text":"<h3>Questions fréquentes</h3>","text_style":"h3","paragraph_font_size":"normal","font_weight":400,"alignment":"left","alignment_mobile":"left","show_read_more":false,"read_more_length":100,"read_more_text":"Voir plus","read_less_text":"Voir moins","truncate":false,"truncate_length":2,"margin_top":0,"margin_bottom":10,"additional_class":""},"blocks":{}},"accordions_JeK8VW":{"type":"accordions","name":"t:accordions","settings":{"show_on_display":"desktop_and_mobile","icon":"caret","dividers":true,"additional_class":""},"blocks":{"accordion_wVm9bk":{"type":"_accordion","settings":{"show_on_display":"desktop_and_mobile","heading":"Politique de retour","open_by_default":false,"icon":"none","icon_custom":"","additional_class":""},"blocks":{"text_b36xbk":{"type":"text","settings":{"show_on_display":"desktop_and_mobile","text":"<p>Notre objectif est que chaque client soit totalement satisfait de son achat. Si ce n'est pas le cas, faites-le nous savoir et nous ferons de notre mieux pour trouver une solution avec vous.</p>","text_style":"paragraph","paragraph_font_size":"normal","font_weight":400,"alignment":"left","alignment_mobile":"left","show_read_more":false,"read_more_length":100,"read_more_text":"Voir plus","read_less_text":"Voir moins","truncate":false,"truncate_length":2,"margin_top":0,"margin_bottom":0,"additional_class":""},"blocks":{}}},"block_order":["text_b36xbk"]},"accordion_FDaFgh":{"type":"_accordion","settings":{"show_on_display":"desktop_and_mobile","heading":"Livraison","open_by_default":false,"icon":"none","icon_custom":"","additional_class":""},"blocks":{"text_yarNag":{"type":"text","settings":{"show_on_display":"desktop_and_mobile","text":"<p>Nos pièces étant <strong>fabriquées à la commande</strong>, votre commande est expédiée sous <strong>3 jours ouvrés</strong>.<br/><br/><strong>Options de livraison :</strong><br/>• <strong>Colissimo</strong> : 2-3 jours ouvrés après expédition<br/>• <strong>Mondial Relais</strong> : 4-6 jours ouvrés après expédition<br/><br/>Vous recevrez un email avec votre numéro de suivi dès l'expédition.</p>","text_style":"paragraph","paragraph_font_size":"normal","font_weight":400,"alignment":"left","alignment_mobile":"left","show_read_more":false,"read_more_length":100,"read_more_text":"Voir plus","read_less_text":"Voir moins","truncate":false,"truncate_length":2,"margin_top":0,"margin_bottom":0,"additional_class":""},"blocks":{}}},"block_order":["text_yarNag"]},"accordion_9NiJU7":{"type":"_accordion","settings":{"show_on_display":"desktop_and_mobile","heading":"Fabrication & matériaux","open_by_default":false,"icon":"none","icon_custom":"","additional_class":""},"blocks":{"text_FP3XGi":{"type":"text","settings":{"show_on_display":"desktop_and_mobile","text":"<p>Toutes nos pièces sont <strong>fabriquées à la commande en France</strong>. Pas de stock dormant : chaque pièce est produite au moment de votre commande, ce qui garantit sa fraîcheur et sa qualité.<br/><br/><strong>Matériaux utilisés :</strong><br/>• <strong>PETG</strong> — résistance mécanique, légèreté, idéal pour les pièces d'habitacle<br/>• <strong>ABS</strong> — robustesse et résistance aux chocs<br/>• <strong>ASA</strong> — résistance aux UV et aux intempéries, pour les pièces exposées<br/><br/>Le matériau est sélectionné selon l'usage et l'environnement de la pièce. Éprouvés sur le <strong>4L Trophy 2026</strong>.</p>","text_style":"paragraph","paragraph_font_size":"normal","font_weight":400,"alignment":"left","alignment_mobile":"left","show_read_more":false,"read_more_length":100,"read_more_text":"Voir plus","read_less_text":"Voir moins","truncate":false,"truncate_length":2,"margin_top":0,"margin_bottom":0,"additional_class":""},"blocks":{}}},"block_order":["text_FP3XGi"]},"accordion_compat":{"type":"_accordion","settings":{"show_on_display":"desktop_and_mobile","heading":"Compatibilité & montage","open_by_default":false,"icon":"none","icon_custom":"","additional_class":""},"blocks":{"text_compat":{"type":"text","settings":{"show_on_display":"desktop_and_mobile","text":"<p>Chaque pièce indique clairement les véhicules compatibles dans sa description. Si vous avez un doute sur la compatibilité avec votre modèle, <strong>contactez-nous avant de commander</strong> via le formulaire de contact.<br/><br/>Le montage ne nécessite généralement pas d'outillage spécifique. Des instructions sont incluses si nécessaire.</p>","text_style":"paragraph","paragraph_font_size":"normal","font_weight":400,"alignment":"left","alignment_mobile":"left","margin_top":0,"margin_bottom":0,"additional_class":""},"blocks":{}}},"block_order":["text_compat"]}},"block_order":["accordion_wVm9bk","accordion_FDaFgh","accordion_9NiJU7","accordion_compat"]}},"block_order":["text_XR3Gyx","accordions_JeK8VW"]}},"block_order":["group_NkNJJg","group_ampbiX"],"name":"t:faq_2","settings":{"show_on_display":"desktop_and_mobile","section_width":"normal","color_scheme":"scheme-2","wrap_in_card":false,"color_sch