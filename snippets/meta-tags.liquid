<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">

{%- liquid
  assign rocaraid_default_description = "Rocaraid — Pièces plastiques rares et accessoires fabriqués en France pour Renault 4L, R5, R6 et motos. Compatibilité garantie, expédié sous 3 jours."
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: rocaraid_default_description

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image %}
  <meta property="og:image" content="http:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{% endif %}

{% if request.page_type == 'index' %}
  {% render 'organization-schema' %}
{% endif %}

{%- if request.page_type == 'product' -%}
  {%- liquid
    assign jm_rating = product.metafields.judgeme.all_reviews_rating.value | default: 4.71
    assign jm_count = product.metafields.judgeme.reviews_count.value | default: 7
    assign product_url = request.origin | append: product.url
    assign product_image_url = ''
    if product.featured_image
      assign product_image_url = product.featured_image | image_url: width: 1200
      assign product_image_url = 'https:' | append: product_image_url
    endif
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "url": {{ product_url | json }},
    "image": {{ product_image_url | json }},
    "brand": {
      "@type": "Brand",
      "name": "Rocaraid"
    },
    "offers": {
      "@type": "Offer",
      "url": {{ product_url | json }},
      "priceCurrency": "EUR",
      "price": {{ product.price | divided_by: 100.0 | json }},
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "seller": {
        "@type": "Organization",
        "name": "Rocaraid"
      },
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "4.00",
          "currency": "EUR"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "FR"
        }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": {{ jm_rating | json }},
      "reviewCount": {{ jm_count | json }},
      "bestRating": "5",
      "worstRating": "1"
    }
  }
  </script>

  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if request.page_type == 'article' -%}
  <script type="application/ld+json">
    {{ article | structured_data }}
  </script>
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

{%- assign has_custom_canonical = false -%}

{% for canonical in shop.metafields.seo.canonicals.value %}
  {%- if request.path == canonical.url -%}
    {%- assign has_custom_canonical = true -%}
    {% comment %} theme-check-disable RemoteAsset {% endcomment %}
    <link rel="canonical" href="{{ canonical.origin_url }}">
    {% comment %} theme-check-enable RemoteAsset {% endcomment %}
  {%- endif -%}
{% endfor %}

{%- unless has_custom_canonical -%}
  <link rel="canonical" href="{{ canonical_url }}">
{%- endunless -%}

{%- for noindex in shop.metafields.seo.no_indexes.value -%}
  {%- if request.path == noindex.url -%}
    <meta name="robots" content="noindex,nofollow">
  {%- endif -%}
{%- endfor -%}

<meta name="description" content="{{ og_description | escape }}">
